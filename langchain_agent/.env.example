# Atlas LangChain Agent — Environment Variables
# Copy this file to .env and fill in your values.

# --- LLM Provider (minimax | deepseek | zhipu) ---
LLM_PROVIDER=minimax
MINIMAX_API_KEY=
# DEEPSEEK_API_KEY=
# ZHIPU_API_KEY=

# --- Financial Data Provider (yfinance | fmp) ---
FINANCIAL_DATA_PROVIDER=yfinance
# FMP_API_KEY=

# --- LangSmith Tracing (opt-in) ---
# Set to true + provide API key to enable full LLM/Tool/Chain tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=atlas-fundamental-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # change for self-hosted

# --- RAG (optional) ---
RAG_FUNDAMENTAL_ENABLED=false
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small

# --- API Auth (empty = disabled, frontend skips login screen) ---
# Set a token here; users must enter it on the frontend unlock screen to access the system.
# ATLAS_API_TOKEN=your-secret-key-here

# --- Server ---
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=info
